{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "ReadGeoipSecrets",
      "Effect": "Allow",
      "Action": ["ssm:GetParameters"],
      "Resource": "arn:aws:ssm:eu-central-1:114930026703:parameter/digiteka-maxmind-worker/*"
    },
    {
      "Sid": "DecryptViaSsm",
      "Effect": "Allow",
      "Action": ["kms:Decrypt"],
      "Resource": "*",
      "Condition": { "StringEquals": { "kms:ViaService": "ssm.eu-central-1.amazonaws.com" } }
    }
  ]
}
